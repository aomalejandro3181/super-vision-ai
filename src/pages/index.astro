---
import AppContainer from "../components/AppContainer";
import AuditorScanner from "../components/AuditorScanner.jsx";
import "../styles/global.css";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<!-- Favicon y PWA Icons -->
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<!-- Colors de la barra de estado del teléfono -->
		<meta name="theme-color" content="#0a192f" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<meta name="apple-mobile-web-app-title" content="SuperVision" />
		<!-- Soporte específico para iOS (Apple Safari) -->
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<meta name="apple-mobile-web-app-title" content="SuperVision" />
		<title>SuperVision.ai - Trade Marketing</title>
	</head>
	<body
		class="bg-purple-100 text-black min-h-screen font-sans antialiased selection:bg-yellow-300"
	>
		<header
			class="bg-[#0a192f] border-b border-slate-800 p-4 sticky top-0 z-50"
		>
			<div class="max-w-md mx-auto flex items-center justify-between">
				<div class="flex items-center gap-3">
					<img
						src="/icons/icon-192x192.png"
						alt="SuperVision.ai Logo"
						class="w-10 h-10 object-contain rounded-lg"
					/>
					<div>
						<h1
							class="text-white font-bold text-lg tracking-wide leading-none"
						>
							SuperVision<span class="text-amber-400">.ai</span>
						</h1>
						<p class="text-xs text-cyan-400 font-medium">
							Trade Marketing Intelligence
						</p>
					</div>
				</div>
				<span
					class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-cyan-950 text-cyan-300 border border-cyan-800"
				>
					<span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"
					></span> v1.0
				</span>
			</div>
		</header>

		<main>
			<AppContainer client:load />
		</main>
	</body>
</html>
